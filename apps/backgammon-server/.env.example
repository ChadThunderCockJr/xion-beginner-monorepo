# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# Auth
SKIP_AUTH_VERIFICATION=true

# Escrow / XION Chain
XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
ESCROW_CONTRACT_ADDRESS=
ESCROW_ADMIN_MNEMONIC=
ADDRESS_PREFIX=xion
GAS_PRICE=0.025uxion

# Gammon Token Redemption
GAMMON_DENOM=factory/xion1.../gammon
GAMMON_DEV_ADDRESS=xion1...
GAMMON_NFT_CONTRACT=
GAMMON_ADMIN_MNEMONIC=

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=1000
# RATE_LIMIT_MAX_MESSAGES=30

# WebSocket
# WS_MAX_PAYLOAD_BYTES=16384

# Timeouts
# DISCONNECT_GRACE_SEC=30
# DISCONNECT_GRACE_DOUBLE_SEC=120
# DISCONNECT_CHECK_INTERVAL_MS=5000
# DOUBLE_DEPOSIT_TIMEOUT_MS=120000
# DEFAULT_TURN_TIME_LIMIT_SEC=60
# INTER_GAME_DELAY_MS=3000

# Auth Nonces
# NONCE_TTL_MS=300000
# NONCE_CLEANUP_INTERVAL_MS=60000

# Clock Defaults
# DEFAULT_CLOCK_TIME_MS=180000
# DEFAULT_CLOCK_INCREMENT_MS=10000

# Matchmaking
# MATCHMAKING_RATING_RANGE=200

# Social / Presence
# ONLINE_HEARTBEAT_TTL_SEC=300
# ONLINE_CLEANUP_INTERVAL_MS=60000
# CHALLENGE_EXPIRY_SEC=60
# MAX_ACTIVITY_ITEMS=50
# MAX_MATCH_HISTORY=100
# MAX_SEARCH_RESULTS=10
# REDIS_SCAN_BATCH_SIZE=200

# Rating System
# RATING_K_PROVISIONAL=40
# RATING_K_INTERMEDIATE=20
# RATING_K_ESTABLISHED=10
# RATING_PROVISIONAL_THRESHOLD=20
# RATING_ESTABLISHED_THRESHOLD=100
# RATING_MIN=100
# RATING_DEFAULT=1500

# Stalling Detection
# STALLING_MIN_MOVES=3
# STALLING_THRESHOLD_PCTG=0.8

# Redemption Polling
# REDEMPTION_POLL_INTERVAL_MS=10000
# NFT_QUERY_LIMIT=30

# Game History
